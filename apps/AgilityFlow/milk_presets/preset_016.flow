{
  "name": "Flow Preset 16 (Organic)",
  "shader": "float aspect = 1920.0/1080.0; float2 v = uv - 0.5; v.x *= aspect; float3 sum = 0; for(int i=0; i<5; i++) { float2 pos = float2(sin(t * (0.2 + i*0.1)), cos(t * (0.3 + i*0.05))) * 0.4; float d = length(v - pos); sum += float3(0.28, 0.81, 0.17) * (0.02 / (d + 0.01)) * (m + 0.2); } float4 p = ptx.Sample(s1, uv * (0.99 * z) + (1.0 - 0.99 * z) * 0.5); return saturate(p * 0.92 + float4(sum, 1.0));"
}